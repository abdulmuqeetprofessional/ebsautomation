#!/bin/bash
################################################################################
# Script Name: ebs_generate_jar.sh
# Author: Abdul Muqeet
# Date: 2026-05-04
# Description: Automated JAR file generation for Oracle E-Business Suite 12.2
#              (RUN edition - non-interactive using defaults file)
#              Sends HTML status email on completion (success or failure).
# Usage: ./ebs_generate_jar.sh
################################################################################

#----------------------- CONFIGURATION SECTION ---------------------------------

# EBS Environment
export EBS_HOME="${HOME}"
export EBS_ENV_FILE="${EBS_HOME}/EBSapps.env"
export ADMIN_DIR="${EBS_HOME}/admin"
export LOG_DIR="${ADMIN_DIR}/log"

# Parallel workers for adadmin (adjust based on system CPU/load)
export WORKERS=4

# Email recipients (space-separated for multiple)
EMAIL_TO="ebs-dba-team@yourcompany.com"
EMAIL_FROM="ebs-automation@yourcompany.com"

# Timestamps
export TIMESTAMP=$(date +%Y%m%d_%H%M%S)
export START_TIME=$(date '+%Y-%m-%d %H:%M:%S')
export START_EPOCH=$(date +%s)

# Defaults file - timestamped to allow rotation
export DEFAULTS_FILE="${ADMIN_DIR}/adadmin_jar_defaults_${TIMESTAMP}.txt"
export LOG_FILE="${LOG_DIR}/generate_jar_${TIMESTAMP}.log"

#----------------------- PRE-FLIGHT CHECKS -------------------------------------

echo "=================================================================="
echo " EBS 12.2 JAR Generation Automation"
echo " Author: Abdul Muqeet"
echo " Started: ${START_TIME}"
echo "=================================================================="

# Check HOME is set
if [ -z "$HOME" ]; then
    echo "[ERROR] HOME directory not set. Exiting."
    exit 1
fi

# Verify EBS environment file exists
if [ ! -f "${EBS_ENV_FILE}" ]; then
    echo "[ERROR] EBS environment file not found: ${EBS_ENV_FILE}"
    exit 1
fi

# Create admin directories if missing
mkdir -p "${ADMIN_DIR}" "${LOG_DIR}"
if [ $? -ne 0 ]; then
    echo "[ERROR] Failed to create directories: ${LOG_DIR}"
    exit 1
fi

# Verify adadmin is available on PATH
command -v adadmin >/dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "[ERROR] adadmin not found in PATH. Ensure EBS environment is sourced."
    exit 1
fi

# Verify mailx is available
command -v mailx >/dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "[WARNING] mailx not found. Email notifications will be skipped."
    MAILX_AVAILABLE=0
else
    MAILX_AVAILABLE=1
fi

#----------------------- SOURCE EBS ENVIRONMENT --------------------------------

echo "[INFO] Sourcing EBS 12.2 RUN edition environment..."
cd "${EBS_HOME}" || exit 1

# shellcheck source=/dev/null
. "${EBS_ENV_FILE}" run

# Verify FILE_EDITION is set to 'run'
if [ "${FILE_EDITION}" != "run" ]; then
    echo "[ERROR] FILE_EDITION is '${FILE_EDITION}', expected 'run'. Exiting."
    exit 1
fi

HOSTNAME=$(hostname -f 2>/dev/null || hostname)
DB_NAME="${TWO_TASK:-${ORACLE_SID:-UNKNOWN}}"

echo "[INFO] Environment loaded successfully."
echo "[INFO] FILE_EDITION : ${FILE_EDITION}"
echo "[INFO] HOSTNAME     : ${HOSTNAME}"
echo "[INFO] DB / TWO_TASK: ${DB_NAME}"
echo "[INFO] DEFAULTS_FILE: ${DEFAULTS_FILE}"
echo "[INFO] LOG_FILE     : ${LOG_FILE}"
echo "[INFO] WORKERS      : ${WORKERS}"

#----------------------- APPS PASSWORD ----------------------------------------

# Read APPS password securely (do not hardcode or pass on command line)
if [ -z "${APPS_PWD}" ]; then
    echo -n "[INPUT] Enter APPS schema password: "
    read -rs APPS_PWD
    echo
fi

if [ -z "${APPS_PWD}" ]; then
    echo "[ERROR] APPS password is required. Exiting."
    exit 1
fi

#----------------------- CREATE DEFAULTS FILE ----------------------------------

echo "[INFO] Preparing adadmin defaults file..."

cat > "${DEFAULTS_FILE}" << EOF
# AD Administration Defaults File
# Auto-generated by ebs_generate_jar.sh
# Author: Abdul Muqeet
# Date: $(date)

# Number of parallel workers
workers=${WORKERS}

# Generate JAR files for all products (blank = all products)
product=

EOF

if [ ! -f "${DEFAULTS_FILE}" ]; then
    echo "[ERROR] Failed to create defaults file: ${DEFAULTS_FILE}"
    exit 1
fi

echo "[INFO] Defaults file created: ${DEFAULTS_FILE}"

#----------------------- EXECUTE JAR GENERATION --------------------------------

echo "[INFO] Starting JAR generation via adadmin..."
echo "[INFO] This may take 15-60 minutes depending on system load."
echo "------------------------------------------------------------------"

# Navigate adadmin menus non-interactively:
#   Main Menu -> 2 (Generate Applications Files menu)
#   Generate Files Menu -> 4 (Generate product JAR files)
#   Confirm regeneration -> yes
#
# Menu selections piped via stdin for silent execution.
# Adjust numbers if your adadmin version differs.

printf "2\n4\nyes\n" | adadmin \
    apps="apps/${APPS_PWD}" \
    defaultsfile="${DEFAULTS_FILE}" \
    logfile="${LOG_FILE}" \
    workers="${WORKERS}"

ADADMIN_EXIT_CODE=$?

#----------------------- POST-EXECUTION ----------------------------------------

END_TIME=$(date '+%Y-%m-%d %H:%M:%S')
END_EPOCH=$(date +%s)
DURATION_SEC=$(( END_EPOCH - START_EPOCH ))
DURATION_MIN=$(( DURATION_SEC / 60 ))
DURATION_REM=$(( DURATION_SEC % 60 ))
DURATION_FMT="${DURATION_MIN}m ${DURATION_REM}s"

echo "------------------------------------------------------------------"
echo "[INFO] adadmin completed with exit code: ${ADADMIN_EXIT_CODE}"
echo "[INFO] Duration: ${DURATION_FMT}"

if [ ${ADADMIN_EXIT_CODE} -eq 0 ]; then
    echo "[SUCCESS] JAR generation completed successfully."
    echo "[SUCCESS] Log file: ${LOG_FILE}"
else
    echo "[WARNING] adadmin exited with non-zero code: ${ADADMIN_EXIT_CODE}"
    echo "[WARNING] Review log file for errors: ${LOG_FILE}"
    if [ -f "${LOG_FILE}" ]; then
        echo "------------------------------------------------------------------"
        echo "[INFO] Last 30 lines of log:"
        tail -30 "${LOG_FILE}"
    fi
fi

#----------------------- HTML EMAIL NOTIFICATION -------------------------------

send_html_email() {
    local exit_code=$1

    # Status-dependent styling
    if [ "${exit_code}" -eq 0 ]; then
        STATUS_LABEL="SUCCESS"
        BANNER_BG="#1a7f37"
        BANNER_ICON="&#10004;"
        STATUS_BADGE_BG="#d4edda"
        STATUS_BADGE_COLOR="#155724"
        STATUS_BADGE_BORDER="#c3e6cb"
    else
        STATUS_LABEL="FAILED"
        BANNER_BG="#b91c1c"
        BANNER_ICON="&#10008;"
        STATUS_BADGE_BG="#f8d7da"
        STATUS_BADGE_COLOR="#721c24"
        STATUS_BADGE_BORDER="#f5c6cb"
    fi

    EMAIL_SUBJECT="[EBS JAR Gen] ${STATUS_LABEL} | ${DB_NAME} | ${HOSTNAME} | ${END_TIME}"

    # Capture last 30 log lines, HTML-escape special characters
    if [ -f "${LOG_FILE}" ]; then
        LOG_TAIL=$(tail -30 "${LOG_FILE}" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g')
    else
        LOG_TAIL="Log file not found: ${LOG_FILE}"
    fi

    HTML_BODY=$(cat << HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EBS JAR Generation - ${STATUS_LABEL}</title>
</head>
<body style="margin:0; padding:0; font-family:Arial,Helvetica,sans-serif;
             font-size:13px; background-color:#f4f6f8; color:#333333;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0"
         style="background-color:#f4f6f8; padding:24px 0;">
    <tr>
      <td align="center">
        <table width="700" cellpadding="0" cellspacing="0" border="0"
               style="background-color:#ffffff; border-radius:6px;
                      box-shadow:0 1px 4px rgba(0,0,0,0.12); overflow:hidden;">

          <!-- ===== BANNER ===== -->
          <tr>
            <td style="background-color:${BANNER_BG}; padding:22px 32px;
                       text-align:center;">
              <span style="font-size:28px; color:#ffffff;">${BANNER_ICON}</span>
              <h1 style="margin:8px 0 4px; font-size:22px; color:#ffffff;
                         font-weight:bold; letter-spacing:1px;">
                EBS 12.2 JAR Generation &mdash; ${STATUS_LABEL}
              </h1>
              <p style="margin:0; font-size:13px; color:rgba(255,255,255,0.85);">
                Oracle E-Business Suite &bull; AD Administration
              </p>
            </td>
          </tr>

          <!-- ===== BODY ===== -->
          <tr>
            <td style="padding:28px 32px 8px;">

              <!-- Status Badge -->
              <table cellpadding="0" cellspacing="0" border="0"
                     style="margin-bottom:24px;">
                <tr>
                  <td style="background-color:${STATUS_BADGE_BG};
                             color:${STATUS_BADGE_COLOR};
                             border:1px solid ${STATUS_BADGE_BORDER};
                             border-radius:4px; padding:8px 18px;
                             font-size:13px; font-weight:bold;">
                    Exit Code: ${exit_code} &nbsp;&bull;&nbsp; ${STATUS_LABEL}
                  </td>
                </tr>
              </table>

              <!-- Section: Execution Summary -->
              <h2 style="font-size:14px; font-weight:bold; color:#1a4a7a;
                         border-bottom:2px solid #1a4a7a; padding-bottom:6px;
                         margin:0 0 14px;">
                &#128203; Execution Summary
              </h2>
              <table width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="border-collapse:collapse; margin-bottom:28px; font-size:13px;">
                <tr style="background-color:#f0f4f8;">
                  <td style="padding:9px 14px; font-weight:bold; width:38%;
                             border:1px solid #dde3ea; color:#555;">Hostname</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${HOSTNAME}</td>
                </tr>
                <tr>
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">Database / TWO_TASK</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${DB_NAME}</td>
                </tr>
                <tr style="background-color:#f0f4f8;">
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">File Edition</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${FILE_EDITION}</td>
                </tr>
                <tr>
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">Workers</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${WORKERS}</td>
                </tr>
                <tr style="background-color:#f0f4f8;">
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">Start Time</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${START_TIME}</td>
                </tr>
                <tr>
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">End Time</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${END_TIME}</td>
                </tr>
                <tr style="background-color:#f0f4f8;">
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">Total Duration</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace;">${DURATION_FMT}</td>
                </tr>
                <tr>
                  <td style="padding:9px 14px; font-weight:bold;
                             border:1px solid #dde3ea; color:#555;">adadmin Exit Code</td>
                  <td style="padding:9px 14px; border:1px solid #dde3ea;
                             font-family:monospace; font-weight:bold;
                             color:${STATUS_BADGE_COLOR};">${exit_code}</td>
                </tr>
              </table>

              <!-- Section: Log File Path -->
              <h2 style="font-size:14px; font-weight:bold; color:#1a4a7a;
                         border-bottom:2px solid #1a4a7a; padding-bottom:6px;
                         margin:0 0 14px;">
                &#128193; Log File Location
              </h2>
              <table width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="margin-bottom:28px;">
                <tr>
                  <td style="background-color:#f8f9fa; border:1px solid #dde3ea;
                             border-radius:4px; padding:11px 16px;
                             font-family:monospace; font-size:12px;
                             word-break:break-all; color:#333;">
                    ${LOG_FILE}
                  </td>
                </tr>
              </table>

              <!-- Section: Last 30 Log Lines -->
              <h2 style="font-size:14px; font-weight:bold; color:#1a4a7a;
                         border-bottom:2px solid #1a4a7a; padding-bottom:6px;
                         margin:0 0 14px;">
                &#128196; Last 30 Lines of Log
              </h2>
              <table width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="margin-bottom:28px;">
                <tr>
                  <td style="background-color:#1e1e1e; border-radius:4px; padding:16px;">
                    <pre style="margin:0; font-family:'Courier New',Courier,monospace;
                                font-size:11px; color:#d4d4d4; white-space:pre-wrap;
                                word-break:break-all; line-height:1.6;">${LOG_TAIL}</pre>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- ===== FOOTER ===== -->
          <tr>
            <td style="background-color:#f0f4f8; padding:14px 32px;
                       border-top:1px solid #dde3ea; text-align:center;">
              <p style="margin:0; font-size:11px; color:#888888;">
                Generated by <strong>ebs_generate_jar.sh</strong>
                &bull; Oracle EBS 12.2 Automation &bull; Author: Abdul Muqeet
                &bull; ${END_TIME}
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
HTMLEOF
)

    echo "${HTML_BODY}" | mailx \
        -a "MIME-Version: 1.0" \
        -a "Content-Type: text/html; charset=UTF-8" \
        -a "From: EBS Automation <${EMAIL_FROM}>" \
        -s "${EMAIL_SUBJECT}" \
        "${EMAIL_TO}"

    if [ $? -eq 0 ]; then
        echo "[INFO] HTML notification email sent to: ${EMAIL_TO}"
    else
        echo "[WARNING] Failed to send notification email."
    fi
}

if [ "${MAILX_AVAILABLE}" -eq 1 ]; then
    echo "[INFO] Sending HTML notification email..."
    send_html_email "${ADADMIN_EXIT_CODE}"
fi

#----------------------- CLEANUP & SUMMARY -------------------------------------

# Rotate defaults files — keep the 5 most recent, delete older ones
ls -1t "${ADMIN_DIR}"/adadmin_jar_defaults_*.txt 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null

echo "=================================================================="
echo " Completed: ${END_TIME}"
echo " Duration:  ${DURATION_FMT}"
echo " Exit Code: ${ADADMIN_EXIT_CODE}"
echo " Log File:  ${LOG_FILE}"
echo "=================================================================="

exit ${ADADMIN_EXIT_CODE}
